[gml_api]
module EpicOnlineServices;

[global, bind = typed_gml]
function eos_test(): real;

group
{

// ============================================================
// EOS API (No Interface)
// ============================================================

[global, bind = typed_gml]
function eos_api_last_error(): string;

[global, bind = typed_gml]
function eos_api_is_initialized(): bool;

[global, bind = typed_gml, type_hint=`EpicResult`]
function eos_api_initialize(product_name: string, product_version: string): gmval;

[global, bind = typed_gml, type_hint=`EpicResult`]
function eos_api_shutdown(): gmval;

[global, bind = typed_gml]
function eos_api_get_version(): string;

[global, bind = typed_gml]
function eos_api_result_to_string([type_hint=`EpicResult`] result: gmval): string;

[global, bind = typed_gml]
function eos_api_result_is_operation_complete([type_hint=`EpicResult`] result: gmval): bool;

[global, bind = typed_gml]
function eos_api_application_status_to_string([type_hint=`EpicApplicationStatus`] status: gmval): string;

[global, bind = typed_gml]
function eos_api_network_status_to_string([type_hint=`EpicNetworkStatus`] status: gmval): string;

[global, bind = typed_gml]
function eos_api_epic_account_id_is_valid(account_id: string): bool;

[global, bind = typed_gml]
function eos_api_product_user_id_is_valid(product_user_id: string): bool;

}


group
{

// ============================================================
// EOS Platform
// ============================================================

[global, bind = typed_gml]
function eos_platform_is_created(): bool;

[global, bind = typed_gml, type_hint=`EpicResult`]
function eos_platform_create(
    is_server: bool,
    product_id: string,
    sandbox_id: string,
    deployment_id: string,
    client_id: string,
    client_secret: string
): gmval;

[global, bind = typed_gml]
function eos_platform_release(): unit;

[global, bind = typed_gml]
function eos_platform_tick(): unit;

[global, bind = typed_gml, type_hint=`EpicResult`]
function eos_platform_check_for_launcher_and_restart(): gmval;

[global, bind = typed_gml, type_hint=`EpicResult`]
function eos_platform_set_network_status([type_hint=`EpicNetworkStatus`] status: gmval): gmval;

}

group
{

// ============================================================
// EOS Logging
// ============================================================

[global]
class `[[EpicLoggingMessage]]` prototype Object
{
    [field, type_hint = `EpicLogCategory`]
    property category : gmval { get; set; }

    [field, type_hint = `EpicLogLevel`]
    property level : gmval { get; set; }

    [field]
    property message : string { get; set; }
}

[global, bind = typed_gml]
function eos_logging_set_callback(callback:func): unit;

[global, bind = typed_gml]
function eos_logging_clear_callback(): unit;

[global, bind = typed_gml, type_hint=`EpicResult`]
function eos_logging_set_log_level(
    [type_hint=`EpicLogCategory`] log_category: gmval,
    [type_hint=`EpicLogLevel`] log_level: gmval
): gmval;

}

